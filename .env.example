# LiveKit Credentials (von https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Piper TTS Server (Server mit de_DE-thorsten-medium starten)
PIPER_URL=http://localhost:5000/

# Ollama (Standard)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# Faster-Whisper (base=CPU, small/medium=mehr RAM)
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=de
# WHISPER_DEVICE=auto
